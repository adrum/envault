{
  "preset": "laravel",
  "rules": {
    "braces": true,
    "no_unused_imports": true,
    "psr_autoloading": true,
    "not_operator_with_successor_space": false,
    "fully_qualified_strict_types": {
      "import_symbols": false
    },
    "ordered_imports": {
      "sort_algorithm": "length"
    },
    "concat_space": {
      "spacing": "one"
    },
    "no_superfluous_phpdoc_tags": false,
    "phpdoc_types": false
  }
}
